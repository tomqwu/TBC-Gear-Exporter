package-as: TBCGearExporter

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

enable-nolib-creation: no

move-folders:
  TBCGearExporter/TBCGearExporter: TBCGearExporter

ignore:
  - .pkgmeta
  - .gitignore
  - .github
  - README.md
  - CHANGELOG.md
  - assets
  - docs
  - tests
  - scripts
  - luacov.report.out
  - luacov.stats.out
